rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Função auxiliar para verificar se o usuário está logado
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Função auxiliar para verificar se o usuário é o dono do documento
    function isOwner(clientId) {
      return isAuthenticated() && request.auth.uid == clientId;
    }

    // Regras para a coleção Connections
    match /connections/{connectionId} {
      allow read, update, delete: if isOwner(resource.data.clientId);
      allow create: if isOwner(request.resource.data.clientId);
    }

    // Regras para a coleção Contacts
    match /contacts/{contactId} {
      allow read, update, delete: if isOwner(resource.data.clientId);
      allow create: if isOwner(request.resource.data.clientId);
    }

    // Regras para a coleção Messages
    match /messages/{messageId} {
      allow read, update, delete: if isOwner(resource.data.clientId);
      allow create: if isOwner(request.resource.data.clientId);
    }
  }
}